{
  "name": "workspace-manager-tui",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "bin": {
    "_wks": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:binary": "node ./scripts/build-binary.mjs ./bin/_wks",
    "dev": "bun run src/cli/index.ts",
    "release": "node ./scripts/release.mjs",
    "start": "bun run dist/cli/index.js",
    "test": "npm run test:unit",
    "test:unit": "vitest run test/config.test.ts test/discovery.test.ts test/workspace.test.ts test/env-export.test.ts",
    "test:e2e": "vitest run test/e2e/*.test.ts"
  },
  "dependencies": {
    "@opentui/core": "^0.1.84",
    "@opentui/react": "^0.1.84",
    "jsonc-parser": "^3.3.1",
    "react": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
